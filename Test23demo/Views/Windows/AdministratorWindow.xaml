<Window x:Class="Test23demo.Views.Windows.AdministratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test23demo.Views.Windows"
        mc:Ignorable="d"
        Title="AdministratorWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="20" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
          
        </Grid.ColumnDefinitions>
        <ListView Name="UsersLv" Grid.Row="2" Grid.ColumnSpan="3">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Логин" DisplayMemberBinding="{Binding Login}"/>
                    <GridViewColumn Header="Роль"  DisplayMemberBinding="{Binding UserRole.Name}"/>
                    <GridViewColumn Header="Блокировка"  DisplayMemberBinding="{Binding IsBlocked}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <Button Name="AddBtn" Click="AddBtn_Click" Grid.Row="0" Grid.Column="0" Height="50" Width="200" Content="Добавить"/>
        <Button Name="EditBtn" Click="EditBtn_Click" Grid.Row="0" Grid.Column="1" Height="50" Width="200" Content="Редактировать"/>
    </Grid>
</Window>
