<Window x:Class="Test23demo.Views.Windows.EditUsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test23demo.Views.Windows"
        mc:Ignorable="d"
        Title="EditUsersWindow" SizeToContent="WidthAndHeight">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="20" />
            <RowDefinition Height="50" />
            <RowDefinition Height="20" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="Логин" />
        <TextBox Grid.Column="2" Name="LoginTb" Text="{Binding Login}"/>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="блокировка"/>
        <CheckBox Grid.Column="2" Grid.Row="2" Name="CheckCb"   />
        <Button Grid.Column="4" Grid.Row="4" Name="EditBtn" Click="EditBtn_Click"  Content="Редактировать"/>
    </Grid>
</Window>
